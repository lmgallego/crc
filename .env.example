# Variables de entorno para desarrollo y producción.
# Copia este archivo a .env.local y rellénalo con tus valores reales.

# === Producción ===
# URL final del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=https://cyclingresearchcenter.org

# === Keystatic (CMS) ===
# Modo local en desarrollo no requiere credenciales.
# Modo GitHub en producción:
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=  # generar con `openssl rand -hex 32`

# === Email (formulario de contacto) ===
# Usar Resend, Plunk o similar
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@crc.org
CONTACT_FROM_EMAIL=no-reply@cyclingresearchcenter.org

# === Analítica (opcional) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cyclingresearchcenter.org
